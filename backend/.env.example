# Database — shared Agriverse PostgreSQL
DATABASE_URL=postgresql://agriverse_user:agriverse_pass@localhost:5432/agriverse

# JWT — must match the Agriverse Node.js backend
JWT_SECRET=your-agriverse-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
