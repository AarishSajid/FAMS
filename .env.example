# FAMS Environment Configuration
# Make a copy of this file and rename it to .env
# Replace the values with your actual configuration before deploying.

# -------------------------
# Database Configuration
# -------------------------
# PostgreSQL credentials used by the 'db' container
POSTGRES_DB=agriverse
POSTGRES_USER=agriverse_user
POSTGRES_PASSWORD=your_secure_password_here

# The connection string used by the 'backend' container (FastAPI / SQLAlchemy)
# Format: postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>
DATABASE_URL=postgresql://agriverse_user:your_secure_password_here@db:5432/agriverse

# -------------------------
# Application Configuration
# -------------------------
# The secret key used for signing JWTs. Must be long and secure in production.
JWT_SECRET=generate_a_random_secure_string_here

# Enable debug mode in FastAPI (true/false)
DEBUG=true

# -------------------------
# Redis Configuration
# -------------------------
REDIS_URL=redis://redis:6379/0
